{
  "name": "virtual-invites",
  "version": "1.0.0",
  "description": "Send digital invites for church-related events",
  "main": "index.js",
  "scripts": {
    "start": "nodemon -r dotenv/config server.js",
    "build": "cd public && npx workbox-cli injectManifest workbox-config.js",
    "ssh:prod": "ssh root@api.usd21.org -p 1773 -i ~/.ssh/usd21/id_rsa",
    "deploy:prod": "ssh root@api.usd21.org -p 1773 -i ~/.ssh/usd21/id_rsa \"cd /var/www/invites.mobi; ./pull.sh\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/USD21Developers/virtual-invites.git"
  },
  "keywords": [
    "icc",
    "international",
    "christian",
    "churches",
    "soldout",
    "discipling",
    "movement",
    "invites"
  ],
